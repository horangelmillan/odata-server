# Security-hardened pnpm configuration for the UI5 OData demo.
# Retires the previous npm/npx approach (no lockfile, runtime registry fetches).
# All dependencies are resolved from the committed pnpm-lock.yaml only.

# Pin exact versions (no ^/~ ranges) — reproducible, auditable installs.
save-exact=true

# Fail if the lockfile is out of sync with package.json (no silent drift).
verify-deps-before-run=error

# In CI / reproducible installs, require the committed lockfile (no network resolve).
prefer-frozen-lockfile=true

# Treat peer-dependency conflicts as errors, not warnings.
strict-peer-dependencies=true
auto-install-peers=true

# Supply-chain hardening: only the packages listed below may run install/build
# scripts. Everything else is installed without executing third-party code.
# `playwright` needs its script to download the browser binaries; @ui5/cli and
# @ui5/linter do NOT require build scripts and are intentionally NOT whitelisted.
only-built-dependencies[]=playwright

# Never run lifecycle scripts implicitly outside the allowlist above.
ignore-scripts=false

# Avoid pulling unrelated workspace packages.
link-workspace-packages=false

# Fail fast on missing peer deps.
