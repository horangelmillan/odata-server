{
  "_version": "2.0.0",
  "sap.app": {
    "id": "ui5.odata.demo",
    "type": "application",
    "title": "UI5 OData V4 Integration Test-Bench",
    "description": "Validates servidor-odata OData V4 endpoint compatibility with SAPUI5/OpenUI5 ODataModel v4.",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "main": {
        "uri": "/odata/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true },
    "supportedThemes": ["sap_horizon"]
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.150.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.table": {},
        "sap.ui.unified": {}
      }
    },
    "models": {
      "": {
        "dataSource": "main",
        "type": "sap.ui.model.odata.v4.ODataModel",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": false,
          "earlyRequests": true,
          "groupId": "$direct",
          "updateGroupId": "changes"
        }
      }
    },
    "contentDensities": { "compact": true, "cozy": true },
    "rootView": {
      "viewName": "ui5.odata.demo.view.App",
      "type": "XML",
      "id": "app"
    }
  }
}
