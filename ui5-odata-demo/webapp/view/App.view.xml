<mvc:View
  controllerName="ui5.odata.demo.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:table="sap.ui.table"
  busyIndicatorDelay="0">

  <App id="app">
    <pages>
      <Page title="UI5 OData V4 &lt;-&gt; servidor-odata Test-Bench">
        <headerContent>
          <Button id="btnRun" text="Run all tests" type="Emphasized" press=".onRunAll"/>
          <Button id="btnReset" text="Reset log" press=".onResetLog"/>
        </headerContent>
        <content>
          <Panel headerText="ProductOData (List binding: $top/$skip/$orderby/$filter/$count/$select)"
                 class="sapUiResponsiveMargin" expandable="true" expanded="true">
            <content>
              <table:Table id="tblProducts"
                rows="{/product-odata}"
                threshold="5"
                enableBusyIndicator="true"
                selectionMode="Single"
                selectionBehavior="Row"
                rowSelectionChange=".onRowSelect"
                ariaLabelledBy="title">
                <table:columns>
                  <table:Column sortProperty="id" filterProperty="id">
                    <Label text="id (Edm.Int32)"/>
                    <table:template><Text text="{id}"/></table:template>
                  </table:Column>
                  <table:Column sortProperty="nombre" filterProperty="nombre">
                    <Label text="nombre (Edm.String)"/>
                    <table:template><Text text="{nombre}"/></table:template>
                  </table:Column>
                  <table:Column sortProperty="precio">
                    <Label text="precio (Edm.Decimal)"/>
                    <table:template><ObjectNumber number="{precio}" unit="EUR"/></table:template>
                  </table:Column>
                  <table:Column>
                    <Label text="categoria"/>
                    <table:template><Text text="{categoria}"/></table:template>
                  </table:Column>
                </table:columns>
              </table:Table>
            </content>
          </Panel>

          <Panel headerText="Selected / expanded entity (by-key + $expand category &amp; products)"
                 class="sapUiResponsiveMargin" expandable="true" expanded="true">
            <content>
              <VBox class="sapUiSmallMargin">
                <HBox><Label text="by-key /product-odata(1): " width="14rem"/><Text id="txtByKey" text="--"/></HBox>
                <HBox><Label text="$expand=category: " width="14rem"/><Text id="txtExpandCat" text="--"/></HBox>
                <HBox><Label text="$expand=products($select=id,nombre;$top=2): " width="14rem"/><Text id="txtExpandProd" text="--"/></HBox>
              </VBox>
            </content>
          </Panel>

          <Panel headerText="Compatibility suite results (window.__suite)"
                 class="sapUiResponsiveMargin" expandable="true" expanded="true">
            <content>
              <TextArea id="log" width="100%" height="320px" editable="false" value=""/>
            </content>
          </Panel>
        </content>
      </Page>
    </pages>
  </App>
</mvc:View>
