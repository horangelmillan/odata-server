#!/bin/sh
# master está CONGELADO también para merges que crean commit.
if [ -z "$ALLOW_MASTER_COMMIT" ]; then
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || git branch --show-current)
  if [ "$branch" = "master" ]; then
    echo "BLOQUEADO: merge sobre 'master' congelado. Usa ALLOW_MASTER_COMMIT=1 solo al finalizar todo."
    exit 1
  fi
fi
