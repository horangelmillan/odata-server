{
    "name": "odata-server",
    "version": "1.0.0",
    "description": "OData v4 server — Node/TypeScript/Express + Modular Monolith + PostgreSQL",
    "main": "./dist/server.js",
    "type": "module",
    "packageManager": "pnpm@9.15.4",
    "engines": {
        "node": "20.18.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev": "node --watch --watch-path ./src --loader ts-node --loader ts-node/esm --no-warnings ./server.ts",
        "build": "tsc --build",
        "start": "node ./dist/server.js",
        "clean": "tsc --build --clean",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "postinstall": "node scripts/patch-odata.mjs"
    },
    "dependencies": {
        "@phrasecode/odata": "^0.3.1",
        "express": "^4.21.1",
        "sequelize": "^6.37.5",
        "pg": "^8.22.0",
        "pg-hstore": "^2.3.4",
        "helmet": "^8.0.0",
        "morgan": "^1.10.0",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "reflect-metadata": "^0.2.2",
        "http-status-codes": "^2.3.0",
        "class-validator": "^0.14.1",
        "class-transformer": "^0.5.1",
        "class-transformer-validator": "^0.9.1",
        "bcrypt": "^5.1.1",
        "jsonwebtoken": "^9.0.2"
    },
    "devDependencies": {
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.7.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3",
        "@vitest/coverage-v8": "^3.1.1",
        "supertest": "^7.1.0",
        "@types/supertest": "^6.0.3",
        "vitest": "^3.1.1"
    }
}
